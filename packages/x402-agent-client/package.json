{
  "name": "@darklrd/x402-agent-client",
  "version": "0.1.2",
  "description": "Client library that auto-handles HTTP 402 payment challenges",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "openai": "^4.80.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "openai": "^4.104.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.5.4"
  },
  "author": "Shashwat Srivastava <shashwat@iflychat.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/darklrd/x402-toolkit.git",
    "directory": "packages/x402-agent-client"
  },
  "homepage": "https://github.com/darklrd/x402-toolkit#readme",
  "bugs": {
    "url": "https://github.com/darklrd/x402-toolkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "x402",
    "http-402",
    "payment",
    "ai-agent",
    "client",
    "micropayment"
