{
  "name": "x402-langchain",
  "version": "0.1.0",
  "description": "LangChain StructuredTool adapter for x402 priced endpoints",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "zod": ">=3.22.0",
    "zod-to-json-schema": ">=3.22.0"
  },
  "dependencies": {
    "x402-agent-client": "workspace:*"
  }
}
