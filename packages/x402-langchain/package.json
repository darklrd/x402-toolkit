{
  "name": "x402-langchain",
  "version": "0.1.1",
  "description": "LangChain StructuredTool adapter for x402 priced endpoints",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "zod": ">=3.22.0",
    "zod-to-json-schema": ">=3.22.0"
  },
  "dependencies": {
    "@darklrd/x402-agent-client": "workspace:*"
  },
  "author": "Shashwat Srivastava <shashwat@iflychat.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/darklrd/x402-toolkit.git",
    "directory": "packages/x402-langchain"
  },
  "homepage": "https://github.com/darklrd/x402-toolkit#readme",
  "bugs": {
    "url": "https://github.com/darklrd/x402-toolkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "x402",
    "http-402",
    "payment",
    "langchain",
    "ai-agent",
    "tool",
    "micropayment"
  ]
}
