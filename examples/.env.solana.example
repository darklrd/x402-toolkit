# Solana payment mode configuration
# Copy this file to .env.solana and fill in your values.
# Load before running: set -a && source examples/.env.solana && set +a && pnpm dev

# ── Shared ───────────────────────────────────────────────────────────────────
PAYMENT_MODE=solana

# Cluster: devnet (default) or mainnet
# devnet  — free test tokens, Circle faucet, ~500ms confirmation
# mainnet — real USDC, paid RPC provider recommended, use 'finalized' commitment
SOLANA_CLUSTER=devnet

# ── Server (paid-weather-tool) ───────────────────────────────────────────────
# Base58 public key of the wallet that will receive payments.
# The USDC ATA for this wallet must be pre-created before starting the server.
#   devnet:  spl-token create-account 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU --owner <pubkey> --url devnet
#   mainnet: spl-token create-account EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v --owner <pubkey> --url mainnet-beta
RECIPIENT_WALLET=<your-pubkey-base58>

# ── Client (cli-agent-demo) ──────────────────────────────────────────────────
# Private key of the wallet that sends payments.
# Accepted formats:
#   base58 string: 5J...abc
#   JSON array:    [12,34,56,...] (Phantom / solana-keygen export)
SOLANA_PRIVATE_KEY=<base58-private-key-or-json-array>

# ── Optional overrides ────────────────────────────────────────────────────────
# Override Solana RPC endpoint.
# devnet default:  https://api.devnet.solana.com  (public, rate-limited)
# mainnet default: https://api.mainnet-beta.solana.com  (public, rate-limited)
# Recommended for mainnet: use a paid provider (Helius, QuickNode, Triton, etc.)
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=<your-key>
